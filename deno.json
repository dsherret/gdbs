{
  "name": "@david/gdbs",
  "version": "0.0.1",
  "lint": {
    "rules": {
      "exclude": [
        "no-explicit-any"
      ]
    }
  },
  "fmt": {
    "operatorPosition": "nextLine"
  },
  "exports": {
    ".": "./mod.ts",
    "./math": "./math.ts",
    "./helpers/binary": "./helpers/binary.ts",
    "./helpers/fetch": "./helpers/fetch.ts",
    "./helpers/github": "./helpers/github.ts",
    "./helpers/temp-dir": "./helpers/temp-dir.ts",
    "./runners/duration": "./runners/duration.ts"
  },
  "imports": {
    "@david/path": "jsr:@david/path@^0.2.0",
    "@david/temp": "jsr:@david/temp@^0.1.1",
    "@david/which": "jsr:@david/which@^0.4.1",
    "@luca/esbuild-deno-loader": "jsr:@luca/esbuild-deno-loader@^0.11.0",
    "@std/assert": "jsr:@std/assert@^1.0.7",
    "@std/fs": "jsr:@std/fs@^1.0.5",
    "@std/http": "jsr:@std/http@^1.0.10",
    "@std/path": "jsr:@std/path@^1.0.8",
    "code-block-writer": "jsr:@david/code-block-writer@13",
    "esbuild": "npm:esbuild@0.20.2"
  }
}
